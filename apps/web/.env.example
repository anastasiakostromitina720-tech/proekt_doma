# Public base URL for the API. Used by the browser fetcher.
# Must be absolute in dev so that credentialed fetch targets the NestJS origin.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Public app URL (used for absolute links, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: align UI labels with the API before any redesign jobs exist (mock | replicate).
# After the first job is loaded, the UI uses the provider from the server.
# NEXT_PUBLIC_REDESIGN_PROVIDER=mock
