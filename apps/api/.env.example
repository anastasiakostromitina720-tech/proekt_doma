# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
API_GLOBAL_PREFIX=api/v1

# Comma-separated list of allowed web origins (CORS). Must be explicit for
# credentialed requests (httpOnly cookie auth).
WEB_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://proekt:proekt@localhost:5432/proekt_doma?schema=public

# -----------------------------------------------------------------------------
# Redis (reserved for BullMQ in later iterations)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Object Storage (MinIO / S3, reserved for later iterations)
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=proekt-doma
STORAGE_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Two independent secrets, each at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_JWT_ACCESS_SECRET=dev_access_secret_change_me_dev_access_secret_change_me
AUTH_JWT_REFRESH_SECRET=dev_refresh_secret_change_me_dev_refresh_secret_change_me

# Access: short-lived (15 min). Refresh: 7 days.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

# Cookie for the refresh token. In production MUST be secure=true.
AUTH_COOKIE_NAME=refresh_token
# AUTH_COOKIE_DOMAIN=  # leave unset in dev; defaults to request host
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# bcrypt cost factor for password hashing. 12 is a good balance for 2026 hardware.
AUTH_BCRYPT_COST=12
